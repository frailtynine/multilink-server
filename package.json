{
  "name": "multilink-server",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npm run build && tsc -p tsconfig.test.json && node --test dist-tests/**/*.test.js",
    "clean": "rm -rf dist dist-tests src/generated",
    "dev": "npm run tsoa:generate && nodemon --watch src --watch tsoa.json --ext ts,json --exec ts-node src/index.ts",
    "tsoa:generate": "tsoa spec-and-routes",
    "build": "npm run clean && npm run tsoa:generate && tsc",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@manhgdev/spotifyweb": "^6.0.2",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@syncfm/applemusic-api": "^0.0.4",
    "@tidal-music/api": "^0.23.0",
    "@tidal-music/auth": "^1.6.0",
    "@types/swagger-ui-express": "^4.1.8",
    "deezer-public-api": "^2.1.4",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0"
  }
